PORT=5000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=change-this-secret
GEMINI_API_KEY=your-server-side-gemini-key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
HF_API_KEY=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
XAI_API_KEY=
XAI_MODEL=grok-2-latest
AI_PROVIDER_ORDER=gemini,groq,openrouter,huggingface,anthropic,openai,xai
AI_TIMEOUT_MS=30000
PUBLIC_BACKEND_URL=http://localhost:5000

# OAuth provider keys. Keep all secrets only in backend .env.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Optional one-click deploy providers for generated websites/apps.
# Keep these only in backend env, never inside the APK.
NETLIFY_AUTH_TOKEN=
VERCEL_TOKEN=
